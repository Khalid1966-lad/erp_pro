generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ AUTH & RBAC ============

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  role          String   @default("operator")
  phone         String?
  isSuperAdmin  Boolean  @default(false)
  isBlocked     Boolean  @default(false)
  isActive      Boolean  @default(true)
  blockedAt     DateTime?
  blockedBy     String?
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  auditLogs     AuditLog[]
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String?
  oldValues   String?
  newValues   String?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════
// GEMA ERP PRO - ENUMS CLIENTS (Maroc)
// ═══════════════════════════════════════════════════════════════

enum FormeJuridique {
  SARL
  SA
  SNC
  SARLAU
  Autre
}

enum LangueCommunication {
  francais
  arabe
  anglais
}

enum ModeReglement {
  virement
  cheque
  effet
  especes
}

enum Incoterm {
  EXW
  FCA
  DAP
  autre
}

enum TauxTVA {
  taux_20
  taux_10
  taux_7
  taux_0
  exonere
  autoliquidation
}

enum ModeFacturation {
  electronique
  papier
}

enum RegimeFiscal {
  IS
  IR
  reel_simplifie
  reel_normal
}

enum StatutClient {
  actif
  inactif
  prospect
  client_risque
  client_privilegie
}

enum CategorieClient {
  grand_compte
  PME
  particulier
  revendeur
  export
}

enum ContactType {
  principal
  commercial
  comptable
  technique
  expedition
}

enum StatutPaiement {
  paye
  impaye
  partiel
}

// ═══════════════════════════════════════════════════════════════
// GEMA ERP PRO - GESTION DES CLIENTS (Maroc)
// ═══════════════════════════════════════════════════════════════

// ============ COMMERCIAL (SALES) ============

model Client {
  id                      String          @id @default(cuid())

  // Legacy fields (kept for backward compatibility with existing frontend)
  name                    String?
  siret                   String?
  address                 String?         // alias → adresse
  city                    String?         // alias → ville
  postalCode              String?         // alias → codePostal
  phone                   String?         // alias → telephone
  country                 String          @default("Maroc")
  creditLimit             Float           @default(0)
  paymentTerms            String          @default("30 jours")
  notes                   String?
  balance                 Float           @default(0)

  // 1. Identité légale (normes Maroc)
  raisonSociale           String?
  nomCommercial           String?
  ice                     String          @unique
  patente                 String?
  cnss                    String?
  identifiantFiscal       String?
  registreCommerce       String?
  villeRC                 String?
  formeJuridique          FormeJuridique  @default(SARL)
  dateCreation            DateTime?

  // 2. Coordonnées
  adresse                 String?
  codePostal              String?
  ville                   String?
  provincePrefecture      String?
  telephone               String?
  gsm                     String?
  email                   String?
  emailSecondaire         String?
  siteWeb                 String?
  langueCommunication     LangueCommunication @default(francais)

  // 3. Paramètres commerciaux
  conditionsPaiement      String          @default("30 jours")
  modeReglementPrefere    ModeReglement   @default(virement)
  escompte                Float           @default(0)
  remisePermanente        Float           @default(0)
  baremePrix              String?
  seuilCredit             Float           @default(0)
  delaiLivraison          Int?
  transporteurPrefere     String?
  incoterm                Incoterm?

  // 4. Paramètres fiscaux & comptables
  tauxTva                 TauxTVA         @default(taux_20)
  codeComptableClient     String          @default("3421")
  modeFacturation         ModeFacturation @default(electronique)
  emailFacturation        String?
  regimeFiscal            RegimeFiscal    @default(IS)

  // 5. Suivi commercial
  datePremierAchat        DateTime?
  dateDernierAchat        DateTime?
  caTotalHT               Float           @default(0)
  nbCommandes             Int             @default(0)
  panierMoyen             Float           @default(0)
  tauxRetour              Float           @default(0)
  dernierDevisDate        DateTime?
  dernierDevisMontant     Float?
  dernierDevisStatut      String?
  derniereFactureDate     DateTime?
  derniereFactureMontant  Float?
  statutPaiement          StatutPaiement?

  // 6. Statut et relation client
  typeSociete             String          @default("SOCIETE")  // SOCIETE, REVENDEUR, PARTICULIER, AUTRES
  statut                  StatutClient    @default(prospect)
  categorie               CategorieClient @default(PME)
  priorite                Int             @default(3)
  origineProspect         String?
  commentairesInternes    String?

  // 7. Relances et litiges
  nbImpayes               Int             @default(0)
  delaiMoyenPaiement      Int             @default(0)
  alerteImpaye            Boolean         @default(false)
  contentieuxNom          String?
  contentieuxEmail        String?
  contentieuxTelephone    String?
  derniereRelanceDate     DateTime?
  derniereRelanceType     String?

  // 8. Spécificités production
  certificationsRequises   String?
  referencesInternes      String?
  specsTechniquesUrl      String?
  packagingInstructions   String?
  planningLivraisonRecurrent String?
  seuilLotMinimal         Int?
  frequenceReporting      String?

  // 9. Champs système
  createdBy               String?
  updatedBy               String?
  version                 Int             @default(1)
  syncId                  String?
  isDeleted               Boolean         @default(false)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  // Relations
  contacts                ClientContact[]
  documents               ClientDocument[]
  quotes                  Quote[]
  salesOrders             SalesOrder[]
  invoices                Invoice[]
  creditNotes             CreditNote[]
  deliveryNotes           DeliveryNote[]
}

model ClientContact {
  id              String      @id @default(cuid())
  clientId        String
  client          Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type            ContactType @default(principal)
  nom             String
  prenom          String
  fonction        String?
  telephoneDirect String?
  email           String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model ClientDocument {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nomFichier  String
  url         String?
  type        String?
  taille      Int?
  createdAt   DateTime @default(now())
}

enum ProductType {
  raw_material
  semi_finished
  finished
}

model Product {
  id            String      @id @default(cuid())
  reference     String      @unique
  designation   String
  description   String?
  priceHT       Float
  tvaRate       Float       @default(20)
  unit          String      @default("unité")
  productType   ProductType @default(raw_material)
  currentStock  Float       @default(0)
  minStock      Float       @default(0)
  maxStock      Float       @default(100)
  averageCost   Float       @default(0)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  bomComponents BomComponent[]
  bomProducts   BomComponent[]  @relation("BomProduct")
  workOrderProducts WorkOrder[]
  quoteLines        QuoteLine[]
  salesOrderLines   SalesOrderLine[]
  invoiceLines      InvoiceLine[]
  creditNoteLines   CreditNoteLine[]
  purchaseOrderLines PurchaseOrderLine[]
  stockMovements    StockMovement[]
  routingSteps      RoutingStep[]
  deliveryNoteLines DeliveryNoteLine[]
}

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  expired
}

model Quote {
  id            String      @id @default(cuid())
  number        String      @unique
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id])
  status        QuoteStatus @default(draft)
  date          DateTime    @default(now())
  validUntil    DateTime
  discountRate  Float       @default(0)
  shippingCost  Float       @default(0)
  notes         String?
  totalHT       Float       @default(0)
  totalTVA      Float       @default(0)
  totalTTC      Float       @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  lines         QuoteLine[]
  salesOrders   SalesOrder[]
}

model QuoteLine {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id])
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Float
  unitPrice   Float
  tvaRate     Float
  totalHT     Float
  discount    Float   @default(0)
}

enum SalesOrderStatus {
  pending
  confirmed
  in_preparation
  prepared
  partially_delivered
  delivered
  cancelled
}

model SalesOrder {
  id            String            @id @default(cuid())
  number        String            @unique
  quoteId       String?
  quote         Quote?            @relation(fields: [quoteId], references: [id])
  clientId      String
  client        Client            @relation(fields: [clientId], references: [id])
  status        SalesOrderStatus  @default(pending)
  date          DateTime          @default(now())
  deliveryDate  DateTime?
  notes         String?
  totalHT       Float             @default(0)
  totalTVA      Float             @default(0)
  totalTTC      Float             @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  lines         SalesOrderLine[]
  invoices      Invoice[]
  preparationOrders PreparationOrder[]
  deliveryNotes  DeliveryNote[]
}

model SalesOrderLine {
  id              String      @id @default(cuid())
  orderId         String
  order           SalesOrder  @relation(fields: [orderId], references: [id])
  productId       String
  product         Product     @relation(fields: [productId], references: [id])
  quantity        Float
  unitPrice       Float
  tvaRate         Float
  totalHT         Float
  quantityPrepared Float       @default(0)
}

enum PreparationStatus {
  pending
  in_progress
  completed
  cancelled
}

model PreparationOrder {
  id            String            @id @default(cuid())
  number        String            @unique
  salesOrderId  String
  salesOrder    SalesOrder        @relation(fields: [salesOrderId], references: [id])
  status        PreparationStatus @default(pending)
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

enum DeliveryNoteStatus {
  draft
  confirmed
  delivered
  cancelled
}

model DeliveryNote {
  id              String              @id @default(cuid())
  number          String              @unique
  salesOrderId    String
  salesOrder      SalesOrder          @relation(fields: [salesOrderId], references: [id])
  clientId        String
  client          Client              @relation(fields: [clientId], references: [id])
  status          DeliveryNoteStatus  @default(draft)
  date            DateTime            @default(now())
  deliveryDate    DateTime?
  transporteur    String?
  vehiclePlate    String?
  notes           String?
  totalHT         Float               @default(0)
  totalTVA        Float               @default(0)
  totalTTC        Float               @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  lines           DeliveryNoteLine[]
}

model DeliveryNoteLine {
  id              String        @id @default(cuid())
  deliveryNoteId  String
  deliveryNote    DeliveryNote  @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  salesOrderLineId String
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Float
  unitPrice       Float
  tvaRate         Float
  totalHT         Float
}

enum InvoiceStatus {
  draft
  validated
  sent
  paid
  overdue
  cancelled
}

model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique
  salesOrderId  String?
  salesOrder    SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  status        InvoiceStatus @default(draft)
  date          DateTime      @default(now())
  dueDate       DateTime
  paymentDate   DateTime?
  discountRate  Float         @default(0)
  shippingCost  Float         @default(0)
  notes         String?
  totalHT       Float         @default(0)
  totalTVA      Float         @default(0)
  totalTTC      Float         @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lines         InvoiceLine[]
  creditNotes   CreditNote[]
  payments      Payment[]
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Float
  unitPrice   Float
  tvaRate     Float
  totalHT     Float
}

enum CreditNoteStatus {
  draft
  validated
  applied
  cancelled
}

model CreditNote {
  id            String            @id @default(cuid())
  number        String            @unique
  invoiceId     String
  invoice       Invoice           @relation(fields: [invoiceId], references: [id])
  clientId      String
  client        Client            @relation(fields: [clientId], references: [id])
  status        CreditNoteStatus  @default(draft)
  date          DateTime          @default(now())
  reason        String?
  totalHT       Float             @default(0)
  totalTVA      Float             @default(0)
  totalTTC      Float             @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  lines         CreditNoteLine[]
}

model CreditNoteLine {
  id            String      @id @default(cuid())
  creditNoteId  String
  creditNote    CreditNote @relation(fields: [creditNoteId], references: [id])
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Float
  unitPrice     Float
  tvaRate       Float
  totalHT       Float
}

// ============ PURCHASING ============

model Supplier {
  id              String    @id @default(cuid())
  name            String
  siret           String?
  address         String?
  city            String?
  postalCode      String?
  country         String    @default("France")
  phone           String?
  email           String?
  deliveryDelay   Int       @default(7)
  paymentTerms    String    @default("30 jours")
  notes           String?
  balance         Float     @default(0)
  rating          Float     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  purchaseOrders  PurchaseOrder[]
}

enum PurchaseOrderStatus {
  draft
  sent
  partially_received
  received
  cancelled
}

model PurchaseOrder {
  id              String                @id @default(cuid())
  number          String                @unique
  supplierId      String
  supplier        Supplier              @relation(fields: [supplierId], references: [id])
  status          PurchaseOrderStatus   @default(draft)
  date            DateTime              @default(now())
  expectedDate    DateTime
  notes           String?
  totalHT         Float                 @default(0)
  totalTVA        Float                 @default(0)
  totalTTC        Float                 @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  lines           PurchaseOrderLine[]
  receptions      Reception[]
}

model PurchaseOrderLine {
  id               String          @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id])
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  quantity         Float
  unitPrice        Float
  tvaRate          Float
  totalHT          Float
  quantityReceived Float           @default(0)
}

model Reception {
  id               String          @id @default(cuid())
  number           String          @unique
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id])
  date             DateTime        @default(now())
  qualityCheck     String          @default("conforme")
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

// ============ STOCK ============

enum MovementType {
  in
  out
  adjustment
}

enum MovementOrigin {
  purchase_reception
  production_input
  production_output
  sale
  return
  inventory_adjustment
  manual
}

model StockMovement {
  id            String        @id @default(cuid())
  productId     String
  product       Product       @relation(fields: [productId], references: [id])
  type          MovementType
  origin        MovementOrigin
  quantity      Float
  unitCost      Float         @default(0)
  documentRef   String?
  notes         String?
  createdAt     DateTime      @default(now())
}

model Inventory {
  id            String    @id @default(cuid())
  number        String    @unique
  type          String    @default("tournant")
  status        String    @default("en_cours")
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lines         InventoryLine[]
}

model InventoryLine {
  id            String    @id @default(cuid())
  inventoryId   String
  inventory     Inventory @relation(fields: [inventoryId], references: [id])
  productId     String
  systemQty     Float
  physicalQty   Float
  difference    Float
  unitCost      Float
  notes         String?
}

// ============ PRODUCTION ============

model BomComponent {
  id            String      @id @default(cuid())
  bomId         String
  bom           Product     @relation("BomProduct", fields: [bomId], references: [id])
  componentId   String
  component     Product     @relation(fields: [componentId], references: [id])
  quantity      Float
  notes         String?

  @@unique([bomId, componentId])
}

model WorkStation {
  id            String          @id @default(cuid())
  name          String
  description   String?
  efficiency    Float           @default(100)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  routingSteps  RoutingStep[]
}

model RoutingStep {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  workStationId String
  workStation   WorkStation @relation(fields: [workStationId], references: [id])
  stepOrder     Int
  duration      Int
  description   String?

  @@unique([productId, stepOrder])
}

enum WorkOrderStatus {
  draft
  planned
  in_progress
  completed
  closed
  cancelled
}

model WorkOrder {
  id              String           @id @default(cuid())
  number          String           @unique
  productId       String
  product         Product          @relation(fields: [productId], references: [id])
  quantity        Float
  status          WorkOrderStatus  @default(draft)
  plannedDate     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  closedAt        DateTime?
  notes           String?
  goodQuantity    Float            @default(0)
  scrapQuantity   Float            @default(0)
  totalCost       Float            @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  steps           WorkOrderStep[]
}

enum StepStatus {
  pending
  in_progress
  completed
  skipped
}

model WorkOrderStep {
  id             String      @id @default(cuid())
  workOrderId    String
  workOrder      WorkOrder   @relation(fields: [workOrderId], references: [id])
  stepOrder      Int
  description    String?
  workStationId  String?
  duration       Int
  actualDuration Int         @default(0)
  status         StepStatus  @default(pending)
  startedAt      DateTime?
  completedAt    DateTime?
  goodQuantity   Float       @default(0)
  scrapQuantity  Float       @default(0)
  notes          String?
}

// ============ FINANCE ============

model CashRegister {
  id            String    @id @default(cuid())
  name          String
  description   String?
  balance       Float     @default(0)
  minBalance    Float     @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  cashMovements CashMovement[]
}

enum CashMovementType {
  in
  out
}

model CashMovement {
  id              String            @id @default(cuid())
  cashRegisterId  String
  cashRegister    CashRegister      @relation(fields: [cashRegisterId], references: [id])
  type            CashMovementType
  amount          Float
  paymentMethod   String            @default("espèces")
  reference       String?
  notes           String?
  createdAt       DateTime          @default(now())
}

model BankAccount {
  id              String            @id @default(cuid())
  name            String
  iban            String
  bic             String?
  balance         Float             @default(0)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  bankTransactions BankTransaction[]
}

model BankTransaction {
  id              String          @id @default(cuid())
  bankAccountId   String
  bankAccount     BankAccount     @relation(fields: [bankAccountId], references: [id])
  date            DateTime
  label           String
  amount          Float
  reference       String?
  isReconciled    Boolean         @default(false)
  reconciledWith  String?
  createdAt       DateTime        @default(now())
}

enum PaymentType {
  client_payment
  supplier_payment
  cash_in
  cash_out
}

enum PaymentMethod {
  cash
  check
  bank_transfer
  card
}

model Payment {
  id              String        @id @default(cuid())
  invoiceId       String?
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id])
  type            PaymentType
  amount          Float
  method          PaymentMethod
  reference       String?
  date            DateTime      @default(now())
  notes           String?
  createdAt       DateTime      @default(now())
}

model AccountingEntry {
  id              String    @id @default(cuid())
  date            DateTime  @default(now())
  label           String
  account         String
  debit           Float     @default(0)
  credit          Float     @default(0)
  documentRef     String?
  createdAt       DateTime  @default(now())
}

// ============ SETTINGS ============

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
