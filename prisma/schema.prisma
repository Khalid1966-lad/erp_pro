generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ AUTH & RBAC ============

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  role          String   @default("operator")
  phone         String?
  isSuperAdmin  Boolean  @default(false)
  isBlocked     Boolean  @default(false)
  isActive      Boolean  @default(true)
  blockedAt     DateTime?
  blockedBy     String?
  avatarUrl     String?
  lastLogin     DateTime?
  lastSeen      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  auditLogs            AuditLog[]
  notifications        Notification[]            @relation("UserNotifications")
  conversationUsers    ConversationParticipant[]  @relation("ConversationUsers")
  sentMessages         Message[]                   @relation("SentMessages")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String?
  oldValues   String?
  newValues   String?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════
// GEMA ERP PRO - ENUMS CLIENTS (Maroc)
// ═══════════════════════════════════════════════════════════════

enum FormeJuridique {
  SARL
  SA
  SNC
  SARLAU
  Autre
}

enum LangueCommunication {
  francais
  arabe
  anglais
}

enum ModeReglement {
  virement
  cheque
  effet
  especes
}

enum Incoterm {
  EXW
  FCA
  DAP
  autre
}

enum TauxTVA {
  taux_20
  taux_10
  taux_7
  taux_0
  exonere
  autoliquidation
}

enum ModeFacturation {
  electronique
  papier
}

enum RegimeFiscal {
  IS
  IR
  reel_simplifie
  reel_normal
}

enum StatutClient {
  actif
  inactif
  prospect
  client_risque
  client_privilegie
}

enum CategorieClient {
  grand_compte
  PME
  particulier
  revendeur
  export
}

enum ContactType {
  principal
  commercial
  comptable
  technique
  expedition
}

enum StatutPaiement {
  paye
  impaye
  partiel
}

// ═══════════════════════════════════════════════════════════════
// GEMA ERP PRO - GESTION DES CLIENTS (Maroc)
// ═══════════════════════════════════════════════════════════════

// ============ COMMERCIAL (SALES) ============

model Client {
  id                      String          @id @default(cuid())

  // Legacy fields (kept for backward compatibility with existing frontend)
  name                    String?
  siret                   String?
  address                 String?         // alias → adresse
  city                    String?         // alias → ville
  postalCode              String?         // alias → codePostal
  phone                   String?         // alias → telephone
  country                 String          @default("Maroc")
  creditLimit             Float           @default(0)
  paymentTerms            String          @default("30 jours")
  notes                   String?
  balance                 Float           @default(0)

  // 1. Identité légale (normes Maroc)
  raisonSociale           String?
  nomCommercial           String?
  ice                     String          @unique
  patente                 String?
  cnss                    String?
  identifiantFiscal       String?
  registreCommerce       String?
  villeRC                 String?
  formeJuridique          FormeJuridique  @default(SARL)
  dateCreation            DateTime?

  // 2. Coordonnées
  adresse                 String?
  codePostal              String?
  ville                   String?
  provincePrefecture      String?
  telephone               String?
  gsm                     String?
  email                   String?
  emailSecondaire         String?
  siteWeb                 String?
  langueCommunication     LangueCommunication @default(francais)

  // 3. Paramètres commerciaux
  conditionsPaiement      String          @default("30 jours")
  modeReglementPrefere    ModeReglement   @default(virement)
  escompte                Float           @default(0)
  remisePermanente        Float           @default(0)
  baremePrix              String?
  seuilCredit             Float           @default(0)
  delaiLivraison          Int?
  transporteurPrefere     String?
  incoterm                Incoterm?

  // 4. Paramètres fiscaux & comptables
  tauxTva                 TauxTVA         @default(taux_20)
  codeComptableClient     String          @default("3421")
  modeFacturation         ModeFacturation @default(electronique)
  emailFacturation        String?
  regimeFiscal            RegimeFiscal    @default(IS)

  // 5. Suivi commercial
  datePremierAchat        DateTime?
  dateDernierAchat        DateTime?
  caTotalHT               Float           @default(0)
  nbCommandes             Int             @default(0)
  panierMoyen             Float           @default(0)
  tauxRetour              Float           @default(0)
  dernierDevisDate        DateTime?
  dernierDevisMontant     Float?
  dernierDevisStatut      String?
  derniereFactureDate     DateTime?
  derniereFactureMontant  Float?
  statutPaiement          StatutPaiement?

  // 6. Statut et relation client
  typeSociete             String          @default("SOCIETE")  // SOCIETE, REVENDEUR, PARTICULIER, AUTRES
  statut                  StatutClient    @default(prospect)
  categorie               CategorieClient @default(PME)
  priorite                Int             @default(3)
  origineProspect         String?
  commentairesInternes    String?

  // 7. Relances et litiges
  nbImpayes               Int             @default(0)
  delaiMoyenPaiement      Int             @default(0)
  alerteImpaye            Boolean         @default(false)
  contentieuxNom          String?
  contentieuxEmail        String?
  contentieuxTelephone    String?
  derniereRelanceDate     DateTime?
  derniereRelanceType     String?

  // 8. Spécificités production
  certificationsRequises   String?
  referencesInternes      String?
  specsTechniquesUrl      String?
  packagingInstructions   String?
  planningLivraisonRecurrent String?
  seuilLotMinimal         Int?
  frequenceReporting      String?

  // 9. Champs système
  createdBy               String?
  updatedBy               String?
  version                 Int             @default(1)
  syncId                  String?
  isDeleted               Boolean         @default(false)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  // Relations
  contacts                ClientContact[]
  documents               ClientDocument[]
  quotes                  Quote[]
  salesOrders             SalesOrder[]
  invoices                Invoice[]
  creditNotes             CreditNote[]
  deliveryNotes           DeliveryNote[]
}

model ClientContact {
  id              String      @id @default(cuid())
  clientId        String
  client          Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type            ContactType @default(principal)
  nom             String
  prenom          String
  fonction        String?
  telephoneDirect String?
  email           String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model ClientDocument {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nomFichier  String
  url         String?
  type        String?
  taille      Int?
  createdAt   DateTime @default(now())
}

model Product {
  id            String      @id @default(cuid())
  reference     String      @unique
  designation   String
  description   String?
  famille       String?
  sousFamille   String?
  priceHT       Float
  tvaRate       Float       @default(20)
  unit          String      @default("unité")
  productNature  String      @default("produit_fini")
  productUsage   String      @default("vente")
  isStockable    Boolean     @default(true)
  currentStock   Float       @default(0)
  minStock       Float       @default(0)
  maxStock       Float       @default(100)
  averageCost    Float       @default(0)
  isActive       Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  bomComponents BomComponent[]
  bomProducts   BomComponent[]  @relation("BomProduct")
  workOrderProducts WorkOrder[]
  quoteLines        QuoteLine[]
  salesOrderLines   SalesOrderLine[]
  invoiceLines      InvoiceLine[]
  creditNoteLines   CreditNoteLine[]
  purchaseOrderLines PurchaseOrderLine[]
  receptionLines    ReceptionLine[]
  priceRequestLines PriceRequestLine[]
  supplierQuoteLines SupplierQuoteLine[]
  supplierInvoiceLines SupplierInvoiceLine[]
  supplierReturnLines SupplierReturnLine[]
  supplierCreditNoteLines SupplierCreditNoteLine[]
  stockMovements    StockMovement[]
  routingSteps      RoutingStep[]
  deliveryNoteLines DeliveryNoteLine[]
  preparationLines  PreparationLine[]
  qualityControlLines QualityControlLine[]
  lots             Lot[]
}

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  expired
}

model Quote {
  id            String      @id @default(cuid())
  number        String      @unique
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id])
  status        QuoteStatus @default(draft)
  date          DateTime    @default(now())
  validUntil    DateTime
  discountRate  Float       @default(0)
  shippingCost  Float       @default(0)
  notes         String?
  totalHT       Float       @default(0)
  totalTVA      Float       @default(0)
  totalTTC      Float       @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  lines         QuoteLine[]
  salesOrders   SalesOrder[]
}

model QuoteLine {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id])
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Float
  unitPrice   Float
  tvaRate     Float
  totalHT     Float
  discount    Float   @default(0)
}

enum SalesOrderStatus {
  pending
  confirmed
  in_preparation
  prepared
  partially_delivered
  delivered
  cancelled
}

model SalesOrder {
  id            String            @id @default(cuid())
  number        String            @unique
  quoteId       String?
  quote         Quote?            @relation(fields: [quoteId], references: [id])
  clientId      String
  client        Client            @relation(fields: [clientId], references: [id])
  status        SalesOrderStatus  @default(pending)
  date          DateTime          @default(now())
  deliveryDate  DateTime?
  notes         String?
  totalHT       Float             @default(0)
  totalTVA      Float             @default(0)
  totalTTC      Float             @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  lines         SalesOrderLine[]
  invoices      Invoice[]
  preparationOrders PreparationOrder[]
  deliveryNotes  DeliveryNote[]
}

model SalesOrderLine {
  id                String      @id @default(cuid())
  orderId           String
  order             SalesOrder  @relation(fields: [orderId], references: [id])
  productId         String
  product           Product     @relation(fields: [productId], references: [id])
  quantity          Float
  unitPrice         Float
  tvaRate           Float
  totalHT           Float
  quantityPrepared  Float       @default(0)
  quantityDelivered Float       @default(0)

  deliveryNoteLines DeliveryNoteLine[]
  preparationLines  PreparationLine[]
}

enum PreparationStatus {
  pending
  in_progress
  completed
  cancelled
}

model PreparationOrder {
  id            String            @id @default(cuid())
  number        String            @unique
  salesOrderId  String
  salesOrder    SalesOrder        @relation(fields: [salesOrderId], references: [id])
  status        PreparationStatus @default(pending)
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  lines         PreparationLine[]
}

enum DeliveryNoteStatus {
  draft
  confirmed
  delivered
  cancelled
}

model DeliveryNote {
  id              String              @id @default(cuid())
  number          String              @unique
  salesOrderId    String?
  salesOrder      SalesOrder?          @relation(fields: [salesOrderId], references: [id])
  clientId        String
  client          Client              @relation(fields: [clientId], references: [id])
  status          DeliveryNoteStatus  @default(draft)
  date            DateTime            @default(now())
  plannedDate     DateTime?
  deliveryDate    DateTime?
  transporteur    String?
  vehiclePlate    String?
  notes           String?
  totalHT         Float               @default(0)
  totalTVA        Float               @default(0)
  totalTTC        Float               @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  lines           DeliveryNoteLine[]
  invoices        InvoiceDeliveryNote[]
}

model DeliveryNoteLine {
  id              String        @id @default(cuid())
  deliveryNoteId  String
  deliveryNote    DeliveryNote  @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  salesOrderLineId String?
  salesOrderLine  SalesOrderLine? @relation(fields: [salesOrderLineId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Float
  unitPrice       Float
  tvaRate         Float
  totalHT         Float
}

enum InvoiceStatus {
  draft
  validated
  sent
  paid
  partially_paid
  overdue
  cancelled
}

model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique
  salesOrderId  String?
  salesOrder    SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  status        InvoiceStatus @default(draft)
  date          DateTime      @default(now())
  dueDate       DateTime
  paymentDate   DateTime?
  discountRate  Float         @default(0)
  shippingCost  Float         @default(0)
  notes         String?
  totalHT       Float         @default(0)
  totalTVA      Float         @default(0)
  totalTTC      Float         @default(0)
  amountPaid    Float         @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lines           InvoiceLine[]
  creditNotes     CreditNote[]
  payments        Payment[]
  paymentLines    PaymentLine[]     @relation("PaymentLineInvoice")
  deliveryNotes   InvoiceDeliveryNote[]
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Float
  unitPrice   Float
  tvaRate     Float
  totalHT     Float
}

enum CreditNoteStatus {
  draft
  validated
  applied
  cancelled
}

model CreditNote {
  id            String            @id @default(cuid())
  number        String            @unique
  invoiceId     String
  invoice       Invoice           @relation(fields: [invoiceId], references: [id])
  clientId      String
  client        Client            @relation(fields: [clientId], references: [id])
  status        CreditNoteStatus  @default(draft)
  date          DateTime          @default(now())
  reason        String?
  totalHT       Float             @default(0)
  totalTVA      Float             @default(0)
  totalTTC      Float             @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  lines         CreditNoteLine[]
}

model CreditNoteLine {
  id            String      @id @default(cuid())
  creditNoteId  String
  creditNote    CreditNote @relation(fields: [creditNoteId], references: [id])
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Float
  unitPrice     Float
  tvaRate       Float
  totalHT       Float
}

// ============ PREPARATION LINES ============

model PreparationLine {
  id                String            @id @default(cuid())
  preparationOrderId String
  preparationOrder  PreparationOrder  @relation(fields: [preparationOrderId], references: [id], onDelete: Cascade)
  salesOrderLineId  String
  salesOrderLine    SalesOrderLine    @relation(fields: [salesOrderLineId], references: [id])
  productId         String
  product           Product           @relation(fields: [productId], references: [id])
  quantityRequested Float
  quantityPrepared  Float             @default(0)
  stockAvailable    Float             @default(0)
  notes             String?
}

// ============ INVOICE-DELIVERY NOTE JUNCTION ============

model InvoiceDeliveryNote {
  id              String        @id @default(cuid())
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  deliveryNoteId  String
  deliveryNote    DeliveryNote  @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, deliveryNoteId])
}

// ============ PURCHASING ============

model Supplier {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String
  siret           String?
  address         String?
  city            String?
  postalCode      String?
  country         String    @default("Maroc")
  phone           String?
  email           String?
  deliveryDelay   Int       @default(7)
  paymentTerms    String    @default("30 jours")
  notes           String?
  balance         Float     @default(0)
  creditLimit     Float     @default(0)
  rating          Float     @default(5)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  purchaseOrders      PurchaseOrder[]
  supplierQuotes     SupplierQuote[]
  supplierInvoices   SupplierInvoice[]
  supplierReturns     SupplierReturn[]
  supplierCreditNotes SupplierCreditNote[]
}

enum PurchaseOrderStatus {
  draft
  sent
  partially_received
  received
  cancelled
}

model PurchaseOrder {
  id              String                @id @default(cuid())
  number          String                @unique
  supplierId      String
  supplier        Supplier              @relation(fields: [supplierId], references: [id])
  supplierQuoteId String?
  supplierQuote    SupplierQuote?        @relation(fields: [supplierQuoteId], references: [id])
  status          PurchaseOrderStatus   @default(draft)
  date            DateTime              @default(now())
  expectedDate    DateTime
  notes           String?
  totalHT         Float                 @default(0)
  totalTVA        Float                 @default(0)
  totalTTC        Float                 @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  lines             PurchaseOrderLine[]
  receptions        Reception[]
  supplierInvoices SupplierInvoice[]
  supplierReturns   SupplierReturn[]
}

model PurchaseOrderLine {
  id               String          @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id])
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  quantity         Float
  unitPrice        Float
  tvaRate          Float
  totalHT          Float
  quantityReceived Float           @default(0)

  receptionLines   ReceptionLine[]
}

model Reception {
  id               String          @id @default(cuid())
  number           String          @unique
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id])
  date             DateTime        @default(now())
  qualityCheck     String          @default("conforme")
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  lines            ReceptionLine[]
  supplierReturns  SupplierReturn[]
  qualityControls  QualityControl[] @relation("QualityControlReception")
}

model ReceptionLine {
  id                 String          @id @default(cuid())
  receptionId        String
  reception          Reception       @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  purchaseOrderLineId String
  purchaseOrderLine  PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id])
  productId          String
  product            Product         @relation(fields: [productId], references: [id])
  expectedQty        Float
  receivedQty        Float
  qualityCheck       String          @default("conforme")
  unitCost           Float           @default(0)
  notes              String?
}

// ============ DEMANDE DE PRIX ============

enum PriceRequestStatus {
  draft
  sent
  answered
  partially_answered
  closed
  cancelled
}

model PriceRequest {
  id              String              @id @default(cuid())
  number          String              @unique
  title           String?
  status          PriceRequestStatus @default(draft)
  date            DateTime            @default(now())
  validUntil      DateTime?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  lines           PriceRequestLine[]
  supplierQuotes  SupplierQuote[]
}

// PriceRequest must NOT have a supplierId (sent to multiple suppliers)

model PriceRequestLine {
  id              String       @id @default(cuid())
  priceRequestId  String
  priceRequest    PriceRequest @relation(fields: [priceRequestId], references: [id], onDelete: Cascade)
  productId       String
  product         Product      @relation(fields: [productId], references: [id])
  quantity        Float
  description     String?
}

// ============ DEVIS FOURNISSEUR ============

enum SupplierQuoteStatus {
  received
  accepted
  rejected
  expired
}

model SupplierQuote {
  id              String              @id @default(cuid())
  number          String              @unique
  priceRequestId  String?
  priceRequest    PriceRequest?       @relation(fields: [priceRequestId], references: [id])
  supplierId      String
  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  status          SupplierQuoteStatus @default(received)
  date            DateTime            @default(now())
  validUntil      DateTime?
  deliveryDelay   Int                 @default(7)
  paymentTerms    String              @default("30 jours")
  notes           String?
  totalHT         Float               @default(0)
  totalTVA        Float               @default(0)
  totalTTC        Float               @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  lines           SupplierQuoteLine[]
  purchaseOrders  PurchaseOrder[]
}

model SupplierQuoteLine {
  id              String         @id @default(cuid())
  supplierQuoteId String
  supplierQuote   SupplierQuote  @relation(fields: [supplierQuoteId], references: [id], onDelete: Cascade)
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  quantity        Float
  unitPrice       Float
  tvaRate         Float           @default(20)
  totalHT         Float           @default(0)
}

// ============ FACTURE FOURNISSEUR ============

enum SupplierInvoiceStatus {
  received
  verified
  paid
  partially_paid
  overdue
  cancelled
}

model SupplierInvoice {
  id               String                @id @default(cuid())
  number           String                @unique
  purchaseOrderId  String?
  purchaseOrder    PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id])
  supplierId       String
  supplier         Supplier              @relation(fields: [supplierId], references: [id])
  status           SupplierInvoiceStatus @default(received)
  date             DateTime              @default(now())
  dueDate          DateTime
  paymentDate      DateTime?
  notes            String?
  totalHT          Float                 @default(0)
  totalTVA         Float                 @default(0)
  totalTTC         Float                 @default(0)
  amountPaid       Float                 @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  lines            SupplierInvoiceLine[]
  supplierReturns  SupplierReturn[]
  supplierCreditNotes SupplierCreditNote[]
  paymentLines     PaymentLine[]     @relation("PaymentLineSupplierInvoice")
}

model SupplierInvoiceLine {
  id                String          @id @default(cuid())
  supplierInvoiceId String
  supplierInvoice   SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)
  productId         String
  product           Product         @relation(fields: [productId], references: [id])
  quantity          Float
  unitPrice         Float
  tvaRate           Float           @default(20)
  totalHT           Float
}

// ============ BON DE RETOUR FOURNISSEUR ============

enum SupplierReturnStatus {
  draft
  sent
  received_by_supplier
  credited
  cancelled
}

model SupplierReturn {
  id               String                @id @default(cuid())
  number           String                @unique
  receptionId      String?
  reception        Reception?            @relation(fields: [receptionId], references: [id])
  purchaseOrderId  String?
  purchaseOrder    PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id])
  supplierInvoiceId String?
  supplierInvoice   SupplierInvoice?      @relation(fields: [supplierInvoiceId], references: [id])
  supplierId       String
  supplier         Supplier              @relation(fields: [supplierId], references: [id])
  status           SupplierReturnStatus @default(draft)
  date             DateTime              @default(now())
  reason           String?
  notes            String?
  totalHT          Float                 @default(0)
  totalTVA         Float                 @default(0)
  totalTTC         Float                 @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  lines               SupplierReturnLine[]
  supplierCreditNotes SupplierCreditNote[]
}

model SupplierReturnLine {
  id              String          @id @default(cuid())
  supplierReturnId String
  supplierReturn  SupplierReturn  @relation(fields: [supplierReturnId], references: [id], onDelete: Cascade)
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  quantity        Float
  unitPrice       Float
  tvaRate         Float           @default(20)
  totalHT         Float
  reason          String?
}

// ============ AVOIR FOURNISSEUR ============

enum SupplierCreditNoteStatus {
  received
  applied
  partially_applied
  cancelled
}

model SupplierCreditNote {
  id                  String                   @id @default(cuid())
  number              String                   @unique
  supplierInvoiceId   String?
  supplierInvoice     SupplierInvoice?         @relation(fields: [supplierInvoiceId], references: [id])
  supplierReturnId    String?
  supplierReturn      SupplierReturn?          @relation(fields: [supplierReturnId], references: [id])
  supplierId          String
  supplier            Supplier                 @relation(fields: [supplierId], references: [id])
  status              SupplierCreditNoteStatus @default(received)
  date                DateTime                 @default(now())
  reason              String?
  totalHT             Float                    @default(0)
  totalTVA            Float                    @default(0)
  totalTTC            Float                    @default(0)
  amountApplied       Float                    @default(0)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  lines               SupplierCreditNoteLine[]
}

model SupplierCreditNoteLine {
  id                   String              @id @default(cuid())
  supplierCreditNoteId String
  supplierCreditNote   SupplierCreditNote @relation(fields: [supplierCreditNoteId], references: [id], onDelete: Cascade)
  productId            String
  product              Product             @relation(fields: [productId], references: [id])
  quantity             Float
  unitPrice            Float
  tvaRate              Float               @default(20)
  totalHT              Float
}

// ============ STOCK ============

enum MovementType {
  in
  out
  adjustment
}

enum MovementOrigin {
  purchase_reception
  production_input
  production_output
  sale
  return
  inventory_adjustment
  manual
  maintenance
}

model StockMovement {
  id            String        @id @default(cuid())
  productId     String
  product       Product       @relation(fields: [productId], references: [id])
  type          MovementType
  origin        MovementOrigin
  quantity      Float
  unitCost      Float         @default(0)
  documentRef   String?
  notes         String?
  createdAt     DateTime      @default(now())
}

model Inventory {
  id            String    @id @default(cuid())
  number        String    @unique
  type          String    @default("tournant")
  status        String    @default("en_cours")
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lines         InventoryLine[]
}

model InventoryLine {
  id            String    @id @default(cuid())
  inventoryId   String
  inventory     Inventory @relation(fields: [inventoryId], references: [id])
  productId     String
  systemQty     Float
  physicalQty   Float
  difference    Float
  unitCost      Float
  notes         String?
}

// ============ PRODUCTION ============

model BomComponent {
  id            String      @id @default(cuid())
  bomId         String
  bom           Product     @relation("BomProduct", fields: [bomId], references: [id])
  componentId   String
  component     Product     @relation(fields: [componentId], references: [id])
  quantity      Float
  notes         String?

  @@unique([bomId, componentId])
}

model WorkStation {
  id            String          @id @default(cuid())
  name          String
  description   String?
  efficiency    Float           @default(100)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  routingSteps  RoutingStep[]
}

model RoutingStep {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  workStationId String
  workStation   WorkStation @relation(fields: [workStationId], references: [id])
  stepOrder     Int
  duration      Int
  description   String?

  @@unique([productId, stepOrder])
}

enum WorkOrderStatus {
  draft
  planned
  in_progress
  completed
  closed
  cancelled
}

enum ProductionBatchStatus {
  pending
  in_progress
  quality_check
  completed
  rejected
}

enum LotStatus {
  actif
  epuise
  bloque
  expire
}

enum LotMouvementType {
  entree
  sortie
  reservation
  annulation_resa
  retour
  ajustement
}

model WorkOrder {
  id              String           @id @default(cuid())
  number          String           @unique
  productId       String
  product         Product          @relation(fields: [productId], references: [id])
  quantity        Float
  status          WorkOrderStatus  @default(draft)
  plannedDate     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  closedAt        DateTime?
  notes           String?
  goodQuantity    Float            @default(0)
  scrapQuantity   Float            @default(0)
  totalCost       Float            @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  steps           WorkOrderStep[]
  qualityControls  QualityControl[] @relation("QualityControlWorkOrder")
  batches         ProductionBatch[]
  lots             Lot[]
}

model ProductionBatch {
  id              String                @id @default(cuid())
  workOrderId     String
  workOrder       WorkOrder             @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  batchNumber     String                @unique
  quantity        Float
  goodQuantity    Float                 @default(0)
  scrapQuantity   Float                 @default(0)
  status          ProductionBatchStatus @default(pending)
  notes           String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

enum StepStatus {
  pending
  in_progress
  completed
  skipped
}

// ============ STOCK LOTS ============

model Lot {
  id              String           @id @default(cuid())
  numeroLot       String           @unique
  productId       String
  product         Product          @relation(fields: [productId], references: [id])
  workOrderId     String?
  workOrder       WorkOrder?       @relation(fields: [workOrderId], references: [id])
  quantiteInitiale Float
  statut          LotStatus        @default(actif)
  dateFabrication DateTime?
  dateExpiration  DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  mouvements      LotMouvement[]
}

model LotMouvement {
  id              String             @id @default(cuid())
  lotId           String
  lot             Lot                @relation(fields: [lotId], references: [id], onDelete: Cascade)
  type            LotMouvementType
  quantite        Float
  documentRef     String?
  documentId      String?
  notes           String?
  createdAt       DateTime           @default(now())
}

model WorkOrderStep {
  id             String      @id @default(cuid())
  workOrderId    String
  workOrder      WorkOrder   @relation(fields: [workOrderId], references: [id])
  stepOrder      Int
  description    String?
  workStationId  String?
  duration       Int
  actualDuration Int         @default(0)
  status         StepStatus  @default(pending)
  startedAt      DateTime?
  completedAt    DateTime?
  goodQuantity   Float       @default(0)
  scrapQuantity  Float       @default(0)
  notes          String?
}

// ============ MAINTENANCE ============

enum EquipementStatut {
  en_service
  en_panne
  en_maintenance
  hors_service
  en_reserve
}

enum EquipementCriticite {
  haute
  moyenne
  basse
}

enum EquipementType {
  extrudeuse
  moule
  compresseur
  four
  decoupeuse
  emballage
  pompe
  moteur
  climatisation
  convoyeur
  generateur
  autre
}

model Equipement {
  id                String            @id @default(cuid())
  code              String            @unique
  designation       String
  type              EquipementType    @default(autre)
  marque            String?
  modele            String?
  numeroSerie       String?
  dateInstallation  DateTime?
  emplacement       String?
  statut            EquipementStatut  @default(en_service)
  criticite         EquipementCriticite @default(moyenne)
  ficheTechnique    String?
  imageBase64       String?
  imageContentType  String?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  plans             PlanMaintenance[]
  ordres            OrdreTravailMaintenance[]
}

enum PlanMaintenanceType {
  temporel
  usage
}

model PlanMaintenance {
  id                  String                @id @default(cuid())
  equipementId        String
  equipement          Equipement            @relation(fields: [equipementId], references: [id], onDelete: Cascade)
  type                PlanMaintenanceType    @default(temporel)
  frequence           Int
  description         String
  piecesNecessaires   String?
  dureeEstimee        Float                 @default(1)
  responsableId       String?
  actif               Boolean               @default(true)
  derniereExecution   DateTime?
  prochaineExecution  DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  ordres              OrdreTravailMaintenance[]
}

enum OTMType {
  preventive
  corrective
  conditionnelle
  ameliorative
}

enum OTMPriorite {
  urgente
  haute
  normale
  basse
}

enum OTMStatut {
  planifiee
  en_cours
  terminee
  validee
  annulee
  en_attente_pieces
}

model OrdreTravailMaintenance {
  id                  String                @id @default(cuid())
  numero              String                @unique
  equipementId        String
  equipement          Equipement            @relation(fields: [equipementId], references: [id])
  planMaintenanceId   String?
  planMaintenance     PlanMaintenance?      @relation(fields: [planMaintenanceId], references: [id])
  typeMaintenance     OTMType               @default(corrective)
  priorite            OTMPriorite           @default(normale)
  statut              OTMStatut             @default(planifiee)
  datePlanifiee       DateTime?
  dateDebut           DateTime?
  dateFin             DateTime?
  description         String
  rapport             String?
  responsableId       String?
  coutPieces          Float                 @default(0)
  coutMainOeuvre      Float                 @default(0)
  machineArretee      Boolean               @default(false)
  arretDebut          DateTime?
  arretFin            DateTime?
  productionPerdue    Float                 @default(0)
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  pieces              OTMPiece[]
}

model OTMPiece {
  id                String                     @id @default(cuid())
  otmId             String
  otm               OrdreTravailMaintenance  @relation(fields: [otmId], references: [id], onDelete: Cascade)
  productId         String
  quantiteNecessaire Float
  quantiteUtilisee  Float                      @default(0)
  coutUnitaire      Float                      @default(0)
}

// ============ QUALITY CONTROL =======================

enum QualityControlType {
  reception
  production_inter
  production_out
  production_final
  inventory
}

enum QualityResult {
  conforme
  non_conforme
  conditionnel
}

enum QualityControlStatus {
  pending
  in_progress
  completed
  rejected
}

model QualityControl {
  id              String              @id @default(cuid())
  type            QualityControlType  @default(reception)
  status          QualityControlStatus @default(pending)
  date            DateTime            @default(now())
  inspector       String?
  notes           String?
  result          QualityResult?
  reference       String?
  
  // Polymorphic link to source entity
  receptionId     String?
  reception       Reception?         @relation("QualityControlReception", fields: [receptionId], references: [id])
  workOrderId     String?
  workOrder       WorkOrder?         @relation("QualityControlWorkOrder", fields: [workOrderId], references: [id])
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  lines           QualityControlLine[]
}

model QualityControlLine {
  id              String          @id @default(cuid())
  qualityControlId String
  qualityControl  QualityControl @relation(fields: [qualityControlId], references: [id], onDelete: Cascade)
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  specification   String?
  measuredValue   String?
  unit            String?
  minValue        Float?
  maxValue        Float?
  tolerance       Float?
  result          QualityResult   @default(conforme)
  notes           String?
}

// ============ FINANCE ============

model CashRegister {
  id            String    @id @default(cuid())
  name          String
  description   String?
  balance       Float     @default(0)
  minBalance    Float     @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  cashMovements CashMovement[]
  payments       Payment[]
}

enum CashMovementType {
  in
  out
}

model CashMovement {
  id              String            @id @default(cuid())
  cashRegisterId  String
  cashRegister    CashRegister      @relation(fields: [cashRegisterId], references: [id])
  type            CashMovementType
  amount          Float
  paymentMethod   String            @default("espèces")
  reference       String?
  notes           String?
  createdAt       DateTime          @default(now())
}

model BankAccount {
  id                String            @id @default(cuid())
  name              String
  iban              String
  bic               String?
  balance           Float             @default(0)
  statementBalance  Float             @default(0)
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  bankTransactions BankTransaction[]
  payments         Payment[]
  effetsCheques    EffetCheque[]
}

model BankTransaction {
  id              String          @id @default(cuid())
  bankAccountId   String
  bankAccount     BankAccount     @relation(fields: [bankAccountId], references: [id])
  date            DateTime
  label           String
  amount          Float
  reference       String?
  isReconciled    Boolean         @default(false)
  reconciledWith  String?
  createdAt       DateTime        @default(now())
}

enum PaymentType {
  client_payment
  supplier_payment
  cash_in
  cash_out
}

enum PaymentMethod {
  cash
  check
  bank_transfer
  card
  effet
}

enum EffetStatut {
  en_attente
  remis_banque
  valide
  rejete
}

// ============ LIGNES DE PAIEMENT (imputation multi-factures) ============

model PaymentLine {
  id                 String            @id @default(cuid())
  paymentId          String
  payment            Payment           @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceId          String?
  invoice            Invoice?          @relation("PaymentLineInvoice", fields: [invoiceId], references: [id])
  supplierInvoiceId  String?
  supplierInvoice    SupplierInvoice?  @relation("PaymentLineSupplierInvoice", fields: [supplierInvoiceId], references: [id])
  amount             Float
  createdAt          DateTime          @default(now())

  @@index([paymentId])
  @@index([invoiceId])
  @@index([supplierInvoiceId])
}

model Payment {
  id              String        @id @default(cuid())
  invoiceId       String?
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id])
  type            PaymentType
  amount          Float
  method          PaymentMethod
  reference       String?
  date            DateTime      @default(now())
  notes           String?
  bankAccountId    String?
  bankAccount      BankAccount?  @relation(fields: [bankAccountId], references: [id])
  cashRegisterId   String?
  cashRegister     CashRegister?  @relation(fields: [cashRegisterId], references: [id])
  createdAt       DateTime      @default(now())

  effetsCheques    EffetCheque[]
  paymentLines     PaymentLine[]
}

// ============ EFFETS DE COMMERCE (Chèques & Lettres de change) ============

model EffetCheque {
  id                String      @id @default(cuid())
  paymentId         String
  payment           Payment     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  bankAccountId     String?
  bankAccount       BankAccount? @relation(fields: [bankAccountId], references: [id])
  type              String      // cheque | effet
  numero            String
  statut            EffetStatut @default(en_attente)
  montant           Float
  beneficiaire      String?
  banqueEmettrice   String?
  dateEmission      DateTime    @default(now())
  dateEcheance      DateTime?
  dateRemiseBanque  DateTime?
  dateValidation    DateTime?
  dateRejet         DateTime?
  causeRejet        String?
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model AccountingEntry {
  id              String    @id @default(cuid())
  date            DateTime  @default(now())
  label           String
  account         String
  debit           Float     @default(0)
  credit          Float     @default(0)
  documentRef     String?
  createdAt       DateTime  @default(now())
}

// ============ NOTIFICATIONS ============

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  title       String
  message     String
  type        String   @default("info")  // info, warning, error, success, task, deadline
  category    String   @default("system") // system, order, delivery, production, payment, stock, message
  entityType  String?  // e.g. "Invoice", "SalesOrder", "DeliveryNote"
  entityId    String?
  actionUrl   String?  // view ID to navigate to (e.g. "invoices", "sales-orders")
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ============ MESSAGING ============

model Conversation {
  id              String    @id @default(cuid())
  isGroup         Boolean   @default(false)
  name            String?   // for group conversations
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  participants    ConversationParticipant[]
  messages        Message[]
}

model ConversationParticipant {
  id              String       @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId          String
  user            User         @relation("ConversationUsers", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt      DateTime?
  createdAt       DateTime     @default(now())

  @@unique([conversationId, userId])
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User         @relation("SentMessages", fields: [senderId], references: [id])
  content         String
  createdAt       DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ============ SETTINGS ============

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// ============ BACKUP & RESTORE ============

model Backup {
  id           String   @id @default(cuid())
  label        String?
  appVersion   String
  schemaHash   String
  dataCompressed String @db.Text
  originalSize Int
  compressedSize Int
  tablesInfo   String   @db.Text
  isValid      Boolean  @default(true)
  createdBy    String?
  createdAt    DateTime @default(now())
}
